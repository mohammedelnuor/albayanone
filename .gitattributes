# Auto detect text files and perform LF normalization
* text=auto eol=lf

# JS and TS files must always use LF for tools to work
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# CSS files must always use LF for tools to work
*.css text eol=lf
*.scss text eol=lf

# JSON files must always use LF for tools to work
*.json text eol=lf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary

# RC files and configs
*.*rc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.lock text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf